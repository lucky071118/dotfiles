root = true

# Defaults for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Python — PEP 8
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

# JavaScript / TypeScript / Node.js
[*.{js,cjs,mjs,ts,cts,mts}]
indent_style = space
indent_size = 2

# JSX / TSX
[*.{jsx,tsx}]
indent_style = space
indent_size = 2

# JSON (package.json, tsconfig, etc.)
[*.{json,jsonc}]
indent_style = space
indent_size = 2

# YAML (GitHub Actions, configs)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# Makefiles require tabs
[Makefile]
indent_style = tab
